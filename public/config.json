{
  "data": [
    {
      "id": "data",
      "label": "Product Data",
      "elements": [
        {
          "id": "name",
          "label": "Product Name",
          "type": "DIMENSION",
          "options": { "min": 1, "max": 1 }
        },
        {
          "id": "category",
          "label": "Category",
          "type": "DIMENSION",
          "options": { "min": 1, "max": 1 }
        },
        {
          "id": "image",
          "label": "Image URL",
          "type": "DIMENSION",
          "options": { "min": 0, "max": 1 }
        },
        {
          "id": "price",
          "label": "Price",
          "type": "METRIC",
          "options": { "min": 1, "max": 1 }
        },
        {
          "id": "inventory",
          "label": "Stock",
          "type": "METRIC",
          "options": { "min": 1, "max": 1 }
        },
        {
          "id": "sales",
          "label": "Sales",
          "type": "METRIC",
          "options": { "min": 1, "max": 1 }
        },
        {
          "id": "ranking",
          "label": "Ranking",
          "type": "METRIC",
          "options": { "min": 0, "max": 1 }
        }
      ]
    }
  ],
  "style": [
    {
      "id": "tooltip",
      "label": "Tooltip",
      "elements": [
        {
          "id": "bgColor",
          "label": "Background color",
          "type": "FILL_COLOR",
          "defaultValue": { "color": "#111111", "opacity": 1 }
        },
        {
          "id": "textColor",
          "label": "Text color",
          "type": "FONT_COLOR",
          "defaultValue": { "color": "#ffffff" }
        }
      ]
    }
  ],
  "interactions": [
    {
      "id": "interactions",
      "supportedActions": ["FILTER"]
    }
  ]
}